#!/usr/bin/env python3
# SPDX-License-Identifier: GPL-3.0-or-later
"""IBus engine for Entropy Universal Symbols.

This backend is intentionally small: it only consumes the reserved transport
keys used by Entropy (F13..F24 plus Ctrl/Shift/Alt banks) and commits the
matching Unicode text through IBus. Other keys are ignored and continue through
the normal input stack.
"""

import signal
import sys

try:
    import gi

    gi.require_version("IBus", "1.0")
    from gi.repository import GLib, IBus
except Exception as exc:  # pragma: no cover - depends on distro packages
    print(
        "Entropy IBus backend requires python3-gi and gir1.2-ibus-1.0: "
        f"{exc}",
        file=sys.stderr,
    )
    sys.exit(1)

ENGINE_NAME = "entropy-universal-symbols"
ENGINE_LONG_NAME = "Entropy Universal Symbols"
ENGINE_DESCRIPTION = "Universal Unicode symbols for Ergohaven keyboards"

XK_F13 = 0xFFCA
KC_F13 = 0x0068
MOD_CTRL = 0x0100
MOD_SHIFT = 0x0200
MOD_ALT = 0x0400


def _symbol_entries():
    entries = []

    def add(offset, symbol, modifiers=0):
        entries.append((KC_F13 + offset, modifiers, symbol))

    # F13..F24
    for idx, symbol in enumerate(["{", "}", "[", "]", "(", ")", "<", ">", "#", "@", "№", "₽"]):
        add(idx, symbol)

    # Shift+F13..F24
    for idx, symbol in enumerate(["!", '"', "$", "%", "&", "'", "*", "+", "=", "?", "|", "\\"]):
        add(idx, symbol, MOD_SHIFT)

    # Ctrl+F13..F24
    for idx, symbol in enumerate(["«", "»", "€", "—", "–", "•", "×", "±", "≠", "≈", "✓", "§"]):
        add(idx, symbol, MOD_CTRL)

    # Alt+F13..F24
    for idx, symbol in enumerate([".", ",", ";", ":", "/", "`", "^"]):
        add(idx, symbol, MOD_ALT)

    # Ctrl+Alt+F13..F19
    for idx, symbol in enumerate(["б", "ю", "ж", "э", "х", "ъ", "ё"]):
        add(idx, symbol, MOD_CTRL | MOD_ALT)

    # Ctrl+Alt+Shift+F13..F19
    for idx, symbol in enumerate(["Б", "Ю", "Ж", "Э", "Х", "Ъ", "Ё"]):
        add(idx, symbol, MOD_CTRL | MOD_ALT | MOD_SHIFT)

    # Ctrl+Shift+F13..F24
    for idx, symbol in enumerate(["°", "‰", "′", "″", "‘", "’", "„", "“", "”", "™", "~", "_"]):
        add(idx, symbol, MOD_CTRL | MOD_SHIFT)

    return entries


SMART_SYMBOLS = {(keycode, modifiers): symbol for keycode, modifiers, symbol in _symbol_entries()}


def _transport_keycode_from_keyval(keyval):
    if XK_F13 <= keyval <= XK_F13 + 11:
        return KC_F13 + (keyval - XK_F13)
    return None


def _transport_modifiers(state):
    modifiers = 0
    if state & IBus.ModifierType.CONTROL_MASK:
        modifiers |= MOD_CTRL
    if state & IBus.ModifierType.SHIFT_MASK:
        modifiers |= MOD_SHIFT
    if state & IBus.ModifierType.MOD1_MASK:
        modifiers |= MOD_ALT
    return modifiers


class EntropyEngine(IBus.Engine):
    def do_process_key_event(self, keyval, keycode, state):
        del keycode
        base_keycode = _transport_keycode_from_keyval(keyval)
        if base_keycode is None:
            return False

        modifiers = _transport_modifiers(state)
        symbol = SMART_SYMBOLS.get((base_keycode, modifiers))
        if symbol is None:
            return False

        # Swallow both key-down and key-up for handled transport keys. Commit
        # text on key-down only.
        if not (state & IBus.ModifierType.RELEASE_MASK):
            self.commit_text(IBus.Text.new_from_string(symbol))
        return True


class EntropyEngineFactory(IBus.Factory):
    def __init__(self, bus):
        super().__init__(connection=bus.get_connection(), object_path=IBus.PATH_FACTORY)
        self._bus = bus
        self._next_engine_id = 0
        self._engines = []

    def do_create_engine(self, engine_name):
        if engine_name != ENGINE_NAME:
            return None
        self._next_engine_id += 1
        path = f"/org/freedesktop/IBus/Entropy/Engine/{self._next_engine_id}"
        engine = EntropyEngine(connection=self._bus.get_connection(), object_path=path)
        self._engines.append(engine)
        return engine


def main():
    IBus.init()
    bus = IBus.Bus()
    if not bus.is_connected():
        print("Entropy IBus backend could not connect to ibus-daemon", file=sys.stderr)
        return 1

    loop = GLib.MainLoop()
    bus.connect("disconnected", lambda *_args: loop.quit())
    EntropyEngineFactory(bus)

    component = IBus.Component(
        name="org.freedesktop.IBus.Entropy",
        description=ENGINE_DESCRIPTION,
        version="1.0.0",
        license="GPL-3.0-or-later",
        author="Ergohaven",
        homepage="https://eh.industries",
        textdomain="entropy",
    )
    component.add_engine(
        IBus.EngineDesc(
            name=ENGINE_NAME,
            longname=ENGINE_LONG_NAME,
            description=ENGINE_DESCRIPTION,
            language="x-other",
            license="GPL-3.0-or-later",
            author="Ergohaven",
            icon="input-keyboard",
            layout="default",
        )
    )
    bus.register_component(component)
    bus.request_name("org.freedesktop.IBus.Entropy", 0)

    signal.signal(signal.SIGINT, lambda *_args: loop.quit())
    signal.signal(signal.SIGTERM, lambda *_args: loop.quit())
    loop.run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
