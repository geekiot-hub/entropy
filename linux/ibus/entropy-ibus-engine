def _qwerty_jcuken_aliases(trigger):
    aliases = []
    alias = _qwerty_jcuken_alias(trigger, map_prefix=False)
    if alias:
        _append_unique(aliases, alias)
    if trigger and trigger[0] in (":", ";"):
        alias = _qwerty_jcuken_prefix_alias(trigger)
        if alias:
            _append_unique(aliases, alias)
        alias = _qwerty_jcuken_alias(trigger, map_prefix=True)
        if alias:
            _append_unique(aliases, alias)
        for alias in _qwerty_jcuken_physical_prefix_aliases(trigger):
            _append_unique(aliases, alias)
    return aliases


def _qwerty_jcuken_physical_prefix_aliases(trigger):
    if not trigger:
        return []
    physical_prefixes = {
        ":": ("^", "6"),
        ";": ("$", "4"),
    }
    prefixes = physical_prefixes.get(trigger[0])
    if not prefixes:
        return []
    aliases = []
    alias = _qwerty_jcuken_alias(trigger, map_prefix=False)
    for physical_prefix in prefixes:
        _append_unique(aliases, physical_prefix + trigger[1:])
        if alias:
            _append_unique(aliases, physical_prefix + alias[1:])
    return aliases


def _qwerty_jcuken_alias(trigger, map_prefix):
    output = []
    changed = False
    for idx, ch in enumerate(trigger):
        if idx == 0 and ch in (":", ";") and not map_prefix:
            output.append(ch)
            continue
        mapped = ch.translate(QWERTY_JCUKEN_ALIASES)
        output.append(mapped)
        changed = changed or mapped != ch
    if not changed:
        return None
    return "".join(output)


def _qwerty_jcuken_prefix_alias(trigger):
    if not trigger:
        return None
    mapped = trigger[0].translate(QWERTY_JCUKEN_ALIASES)
    if mapped == trigger[0]:
        return None
    return mapped + trigger[1:]


def _decode_text_escapes(raw):
    output = []
    idx = 0
    while idx < len(raw):
        ch = raw[idx]
        if ch == "\\" and idx + 1 < len(raw):
            nxt = raw[idx + 1]
            if nxt == "n":
                output.append("\n")
                idx += 2
                continue
            if nxt == "t":
                output.append("\t")
                idx += 2
                continue
            if nxt == "r":
                output.append("\r")
                idx += 2
                continue
            if nxt == "\\":
                output.append("\\")
                idx += 2
                continue
        output.append(ch)
        idx += 1
    return "".join(output)


def _prepare_replacement(raw):
    expanded = _decode_text_escapes(raw)
    marker = "$|$"
    marker_idx = expanded.find(marker)
    if marker_idx < 0:
        return expanded, 0
    before = expanded[:marker_idx]
    after = expanded[marker_idx + len(marker):]
    return before + after, len(after)


def _is_word_char(ch):
    return ch.isalnum() or ch == "_"


class TextExpansionEngine:
    def __init__(self):
        self.rules = []
        self.buffer = ""
        self.max_buffer_chars = 64

    def set_rules(self, rules):
        self.rules = [rule for rule in rules if isinstance(rule, dict)]
        max_trigger_chars = 0
        for rule in self.rules:
            if not _rule_usable(rule):
                continue
            for trigger in _activation_triggers(str(rule.get("trigger", ""))):
                max_trigger_chars = max(max_trigger_chars, len(trigger))
        self.max_buffer_chars = min(max(max_trigger_chars, 64), 128)
        self.reset()

    def reset(self):
        self.buffer = ""

    def seed_tail(self, text):
        if not text:
            return
        self.buffer = text[-self.max_buffer_chars :]

    def backspace(self):
        self.buffer = self.buffer[:-1]

    def push_char(self, ch):
        if ord(ch) < 32:
            self.reset()
            return None
        self.buffer += ch
        if len(self.buffer) > self.max_buffer_chars:
            self.buffer = self.buffer[-self.max_buffer_chars:]
        match = self._find_match()
        if match is not None:
            self.reset()
        return match

    def _find_match(self):
        matches = []
        for rule in self.rules:
            if not _rule_usable(rule):
                continue
            for trigger in _activation_triggers(str(rule.get("trigger", ""))):
                if not self.buffer.endswith(trigger):
                    continue
                if not self._boundary_ok(trigger):
                    continue
                if self._has_longer_pending_trigger(trigger):
                    continue
                replacement, cursor_back_chars = _prepare_replacement(str(rule.get("replacement", "")))
                matches.append((len(trigger), replacement, cursor_back_chars))
        if not matches:
            return None
        typed_trigger_chars, replacement, cursor_back_chars = max(matches, key=lambda item: item[0])
        return typed_trigger_chars, replacement, cursor_back_chars

    def _has_longer_pending_trigger(self, trigger):
        for rule in self.rules:
            if not _rule_usable(rule):
                continue
            for candidate in _activation_triggers(str(rule.get("trigger", ""))):
                if len(candidate) > len(trigger) and candidate.startswith(trigger):
                    return True
        return False

    def _boundary_ok(self, trigger):
        if not trigger:
            return False
        if not _is_word_char(trigger[0]):
            return True
        if len(self.buffer) <= len(trigger):
            return True
        return not _is_word_char(self.buffer[-len(trigger) - 1])


class TextExpanderRuntime:
    def __init__(self):
        self.enabled = False
        self.engine = TextExpansionEngine()
        self._signature = None

    def reload_if_needed(self):
        paths = [_app_settings_path(), _rules_path()]
        settings = _read_json_file(_app_settings_path())
        if isinstance(settings, dict):
            for raw in settings.get("text_expander_rule_files", []):
                name = _normalize_extra_rule_file(raw)
                if name:
                    paths.append(_rules_path(name))
        signature = tuple((path, self._mtime(path)) for path in paths)
        if signature == self._signature:
            return
        self._signature = signature
        self._load(settings)

    def _load(self, settings):
        if not isinstance(settings, dict):
            self.enabled = False
            self.engine.set_rules([])
            return
        self.enabled = bool(settings.get("text_expander_enabled", False))
        rules = []
        primary = _parse_rules_json(_read_json_file(_rules_path()))
        if primary:
            rules.extend(primary)
        else:
            rules.extend(settings.get("text_expansion_rules", []))
        for raw in settings.get("text_expander_rule_files", []):
            name = _normalize_extra_rule_file(raw)
            if name:
                rules.extend(_parse_rules_json(_read_json_file(_rules_path(name))))
        self.engine.set_rules(rules)

    @staticmethod
    def _mtime(path):
        try:
            return os.path.getmtime(path)
        except OSError:
            return None

    def active(self):
        return self.enabled and bool(self.engine.rules)


SHARED_TEXT_EXPANDER_RUNTIME = TextExpanderRuntime()


def _transport_keycode_from_keyval(keyval):
    if XK_F13 <= keyval <= XK_F13 + 11:
        return KC_F13 + (keyval - XK_F13)
    return None


def _transport_keycode_from_event(keyval, keycode):
    by_keyval = _transport_keycode_from_keyval(keyval)
    if by_keyval is not None:
        return by_keyval, "keyval"
    if EVDEV_F13_KEYCODE <= keycode <= EVDEV_F13_KEYCODE + 11:
        return KC_F13 + (keycode - EVDEV_F13_KEYCODE), "evdev-keycode"
    if XKB_F13_KEYCODE <= keycode <= XKB_F13_KEYCODE + 11:
        return KC_F13 + (keycode - XKB_F13_KEYCODE), "xkb-keycode"
    return None, None


def _transport_modifiers(state):
    modifiers = 0
    if state & IBus.ModifierType.CONTROL_MASK:
        modifiers |= MOD_CTRL
    if state & IBus.ModifierType.SHIFT_MASK:
        modifiers |= MOD_SHIFT
    if state & IBus.ModifierType.MOD1_MASK:
        modifiers |= MOD_ALT
    return modifiers


class EntropyEngine(IBus.Engine):
    def __init__(self, *args, **kwargs):
        super().__init__(*args, **kwargs)
        self._text_expander = SHARED_TEXT_EXPANDER_RUNTIME
        self._client = ""
        self._client_capabilities = 0
        self._input_purpose = IBus.InputPurpose.FREE_FORM

    def do_focus_in_id(self, object_path, client):
        del object_path
        self._client = str(client or "").lower()

    def do_focus_out_id(self, object_path):
        del object_path
        self._client = ""

    def do_set_capabilities(self, caps):
        self._client_capabilities = int(caps)

    def do_set_content_type(self, purpose, hints):
        del hints
        self._input_purpose = purpose

    def do_process_key_event(self, keyval, keycode, state):
        base_keycode, source = _transport_keycode_from_event(keyval, keycode)
        if base_keycode is not None:
            modifiers = _transport_modifiers(state)
            symbol = SMART_SYMBOLS.get((base_keycode, modifiers))
            del source
            if symbol is not None:
                # Commit text on key-down only.
                if not (state & IBus.ModifierType.RELEASE_MASK):
                    self.commit_text(IBus.Text.new_from_string(symbol))
            return True

        return self._process_text_expander_key(keyval, keycode, state)

    def _process_text_expander_key(self, keyval, keycode, state):
        del keycode
        if state & IBus.ModifierType.RELEASE_MASK:
            return False

        self._text_expander.reload_if_needed()
        if not self._text_expander.active():
            return False

        engine = self._text_expander.engine
        if keyval == IBus.KEY_BackSpace:
            engine.backspace()
            return False
        if _text_expander_reset_key(keyval):
            engine.reset()
            return False
        if _text_expander_modifier_active(state):
            return False

        ch = _text_expander_key_char(keyval, state)
        if ch is None:
            return False
        self._seed_text_expander_from_surrounding_text(engine)
        expansion = engine.push_char(ch)
        if expansion is None:
            return False

        typed_trigger_chars, replacement, cursor_back_chars = expansion
        previous_chars = max(typed_trigger_chars - 1, 0)
        if self._is_terminal_context() and previous_chars:
            self.commit_text(IBus.Text.new_from_string("\x7f" * previous_chars + replacement))
        else:
            if previous_chars and not self.delete_surrounding_text(-previous_chars, previous_chars):
                for _ in range(previous_chars):
                    self.forward_key_event(IBus.KEY_BackSpace, 0, 0)
                    self.forward_key_event(
                        IBus.KEY_BackSpace, 0, IBus.ModifierType.RELEASE_MASK
                    )
            self.commit_text(IBus.Text.new_from_string(replacement))
        for _ in range(cursor_back_chars):
            self.forward_key_event(IBus.KEY_Left, 0, 0)
        return True

    def _is_terminal_context(self):
        if self._input_purpose == IBus.InputPurpose.TERMINAL:
            return True
        return any(marker in self._client for marker in TERMINAL_CLIENT_MARKERS)

    def _seed_text_expander_from_surrounding_text(self, engine):
        try:
            text, cursor_pos, _anchor_pos = self.get_surrounding_text()
        except (AttributeError, TypeError, ValueError):
            return
        if text is None or cursor_pos is None:
            return
        surrounding = text.get_text()
        if not surrounding:
            return
        try:
            cursor_pos = int(cursor_pos)
        except (TypeError, ValueError):
            return
        before_cursor = surrounding[: max(cursor_pos, 0)]
        if before_cursor:
            engine.seed_tail(before_cursor)


def _text_expander_reset_key(keyval):
    return keyval in {
        IBus.KEY_Return,
        IBus.KEY_KP_Enter,
        IBus.KEY_Tab,
        IBus.KEY_Escape,
        IBus.KEY_Left,
        IBus.KEY_Up,
        IBus.KEY_Right,
        IBus.KEY_Down,
    }


def _text_expander_modifier_active(state):
    masks = [
        IBus.ModifierType.CONTROL_MASK,
        IBus.ModifierType.MOD1_MASK,
        getattr(IBus.ModifierType, "SUPER_MASK", 0),
        getattr(IBus.ModifierType, "HYPER_MASK", 0),
        getattr(IBus.ModifierType, "META_MASK", 0),
    ]
    return any(mask and (state & mask) for mask in masks)


SHIFT_ASCII_CHARS = {
    "`": "~",
    "1": "!",
    "2": "@",
    "3": "#",
    "4": "$",
    "5": "%",
    "6": "^",
    "7": "&",
    "8": "*",
    "9": "(",
    "0": ")",
    "-": "_",
    "=": "+",
    "[": "{",
    "]": "}",
    "\\": "|",
    ";": ":",
    "'": '"',
    ",": "<",
    ".": ">",
    "/": "?",
}


def _text_expander_key_char(keyval, state):
    value = IBus.keyval_to_unicode(keyval)
    if isinstance(value, str):
        if not value:
            return None
        ch = value[0]
    elif isinstance(value, int):
        if value <= 0:
            return None
        ch = chr(value)
    else:
        return None
    if state & IBus.ModifierType.SHIFT_MASK:
        if ch in SHIFT_ASCII_CHARS:
            return SHIFT_ASCII_CHARS[ch]
        if "a" <= ch <= "z":
            return ch.upper()
    return ch


class EntropyEngineFactory(IBus.Factory):
    def __init__(self, bus):
        super().__init__(connection=bus.get_connection(), object_path=IBus.PATH_FACTORY)
        self._bus = bus
        self._next_engine_id = 0
        self._engines = []

    def do_create_engine(self, engine_name):
        if engine_name not in ENGINE_NAMES:
            return None
        self._next_engine_id += 1
        path = f"/org/freedesktop/IBus/Entropy/Engine/{self._next_engine_id}"
        engine = EntropyEngine(connection=self._bus.get_connection(), object_path=path)
        self._engines.append(engine)
        return engine


def main():
    if len(sys.argv) > 1 and sys.argv[1] == "--entropy-check":
        print("Entropy IBus backend dependencies ok")
        return 0

    IBus.init()
    bus = IBus.Bus()
    if not bus.is_connected():
        print("Entropy IBus backend could not connect to ibus-daemon", file=sys.stderr)
        return 1

    loop = GLib.MainLoop()
    bus.connect(
        "disconnected",
        lambda *_args: loop.quit(),
    )
    EntropyEngineFactory(bus)

    component = IBus.Component(
        name="org.freedesktop.IBus.Entropy",
        description=ENGINE_DESCRIPTION,
        version="1.0.0",
        license="GPL-3.0-or-later",
        author="Ergohaven",
        homepage="https://eh.industries",
        textdomain="entropy",
    )
    for engine_descriptor in ENGINE_DESCRIPTORS:
        component.add_engine(
            IBus.EngineDesc(
                name=engine_descriptor["name"],
                longname=engine_descriptor["longname"],
                description=ENGINE_DESCRIPTION,
                language=engine_descriptor["language"],
                license="GPL-3.0-or-later",
                author="Ergohaven",
                icon="input-keyboard",
                layout=engine_descriptor["layout"],
            )
        )
    bus.register_component(component)
    bus.request_name("org.freedesktop.IBus.Entropy", 0)

    signal.signal(
        signal.SIGINT,
        lambda *_args: loop.quit(),
    )
    signal.signal(
        signal.SIGTERM,
        lambda *_args: loop.quit(),
    )
    loop.run()
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
