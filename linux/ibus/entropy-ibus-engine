def _rules_dir():
    return os.path.join(_entropy_config_dir(), "text_expander_rules")


def _rules_path(file_name=TEXT_EXPANDER_MAIN_RULES_FILE):
    return os.path.join(_rules_dir(), file_name)


def _normalize_extra_rule_file(raw):
    name = os.path.basename(str(raw).strip())
    if not name:
        return None
    if name.lower() == TEXT_EXPANDER_MAIN_RULES_FILE.lower():
        return None
    if not name.lower().endswith(".json"):
        return None
    return name


def _read_json_file(path):
    try:
        with open(path, "r", encoding="utf-8") as handle:
            return json.load(handle)
    except Exception:
        return None


def _parse_rules_json(data):
    if isinstance(data, list):
        return data
    if isinstance(data, dict):
        for key in ("rules", "text_expansion_rules"):
            value = data.get(key)
            if isinstance(value, list):
                return value
    return []


def _rule_usable(rule):
    return (
        bool(rule.get("enabled", True))
        and bool(_activation_triggers(str(rule.get("trigger", ""))))
        and bool(_prepare_replacement(str(rule.get("replacement", "")))[0])
    )


def _valid_trigger(trigger):
    return (
        trigger.strip() == trigger
        and len(trigger) >= 2
        and trigger[0] in (":", ";")
        and not any(ch.isspace() for ch in trigger)
        and not any(ord(ch) < 32 for ch in trigger)
    )


def _valid_legacy_trigger_stem(trigger):
    return (
        trigger.strip() == trigger
        and len(trigger) >= 1
        and trigger[0] not in (":", ";")
        and not any(ch.isspace() for ch in trigger)
        and not any(ord(ch) < 32 for ch in trigger)
    )


def _activation_triggers(trigger):
    if _valid_trigger(trigger):
        base = [trigger]
    elif _valid_legacy_trigger_stem(trigger):
        base = [f":{trigger}", f";{trigger}"]
    else:
        return []

    triggers = []
    for item in base:
        _append_unique(triggers, item)
        for alias in _qwerty_jcuken_aliases(item):
            _append_unique(triggers, alias)
    return triggers


def _append_unique(items, item):
    if item not in items:
        items.append(item)


